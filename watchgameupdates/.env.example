APP_ENV=

# Logging
LOG_FORMAT=json          # "json" (default) or "text" for human-readable structured output
LOG_LEVEL=info           # "debug", "info" (default), "warn", "error"

# Cloud Tasks Configuration (HTTP mode: -mode=http)
CLOUD_TASKS_EMULATOR_HOST=
GCP_PROJECT_ID=
GCP_LOCATION=
CLOUD_TASKS_QUEUE=
HANDLER_HOST=
# MESSAGE_INTERVAL_SECONDS: how often to poll during active play (default: 60)
MESSAGE_INTERVAL_SECONDS=60
# PERIOD_END_INTERVAL_SECONDS: wait time after period ends before next check (default: 1200 = 20min)
PERIOD_END_INTERVAL_SECONDS=1200

# Redis Configuration (worker mode: -mode=worker)
REDIS_ADDRESS=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Task Scheduling
MESSAGE_INTERVAL_SECONDS=60

# API Configuration
PLAYBYPLAY_API_BASE_URL=
STATS_API_BASE_URL=

# Discord Bot Configuration
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=          # Discord channel ID to post game updates

# Live Activity (APNs broadcast push)
LIVEACTIVITY_PUSH_ENABLED=   # Set to "true" to enable
APNS_TEAM_ID=                # 10-char Apple Developer Team ID
APNS_KEY_ID=                 # .p8 key ID from App Store Connect
APNS_AUTH_KEY=               # base64-encoded .p8 file: base64 -i AuthKey_KEYID.p8
APNS_TOPIC=                  # Bundle ID, e.g. me.blakenelson.firepower
APNS_HOST=                   # api.sandbox.push.apple.com (dev) or api.push.apple.com (prod)

# Scheduler Configuration
SCHEDULE_API_BASE_URL=         # NHL schedule API (defaults to PLAYBYPLAY_API_BASE_URL)
SCHEDULE_FILE=                 # Path to local JSON schedule file (empty = use API)
SCHEDULE_DATE=                 # Override target date YYYY-MM-DD (empty = today)
GAME_MAX_DURATION_HOURS=5      # Hours after game start for execution window
SCHEDULER_SHOULD_NOTIFY=true   # Enable Discord notifications for scheduled games

# Grafana Cloud Loki (used by Grafana Alloy sidecar — not the Go app directly)
# Run `make grafana-live` or `make grafana-emulator` to activate log shipping.
# See docs/grafana-loki-setup.md for setup instructions.
GRAFANA_LOKI_URL=        # e.g. https://logs-prod-006.grafana.net/loki/api/v1/push
GRAFANA_LOKI_USER=       # Grafana Cloud numeric instance ID
GRAFANA_LOKI_API_KEY=    # API key with "Logs Writer" role
